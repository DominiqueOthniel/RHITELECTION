# Développement local : copier ce fichier en `.env.local` et remplir les valeurs.
# Vercel : Project → Settings → Environment Variables (Production / Preview / Development).

# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secrète — uniquement côté serveur (ne jamais préfixer par NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
